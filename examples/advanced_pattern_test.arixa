// Test 9: Pattern matching with complex or-patterns
fn test_complex_or_patterns() Int {
    point = Point(3, 4);
    
    match point {
        Point { x: 0, y: 0 } | Point { x: 1, y: 1 } => print("Origin or (1,1)"),
        Point { x: x, y: y } if x == y => print("On diagonal"),
        Point { x: x, y: 0 } | Point { x: 0, y: y } => print("On axis"),
        Point { x, y } if x > 0 && y > 0 => print("First quadrant"),
        Point { x, y } if x < 0 && y < 0 => print("Third quadrant"),
        _ => print("Other quadrant"),
    }
    
    return 0;
}

// Test 10: Pattern matching with string literals
fn test_string_patterns() Int {
    message = "hello world";
    
    match message {
        "hello" => print("Simple hello"),
        "hello world" => print("Hello world"),
        s if s.len() > 10 => print("Long string: " + s),
        s if s.len() < 5 => print("Short string: " + s),
        s => print("Medium string: " + s),
    }
    
    return 0;
}

// Test 11: Pattern matching with boolean logic in guards
fn test_boolean_logic_guards() Int {
    x = 15;
    y = 20;
    
    match (x, y) {
        (a, b) if a > 0 && b > 0 => print("Both positive"),
        (a, b) if a < 0 && b < 0 => print("Both negative"),
        (a, b) if a * b > 0 => print("Same sign"),
        (a, b) if a + b == 0 => print("Opposites sum to zero"),
        (a, b) if a > b => print("First greater"),
        (a, b) if a < b => print("Second greater"),
        (a, b) => print("Equal"),
    }
    
    return 0;
}

// Test 12: Exhaustiveness checking
fn test_exhaustiveness() Int {
    value = Option::Some(42);
    
    // This should pass exhaustiveness checking
    match value {
        Option::None => print("None"),
        Option::Some(v) => print("Some: " + to_string_int(v)),
    }
    
    // This would fail exhaustiveness checking if Option::None case is missing
    // match value {
    //     Option::Some(v) => print("Some: " + to_string_int(v)),
    // }
    
    return 0;
}

fn main() Int {
    print("Testing advanced pattern matching...");
    
    test_deep_nesting();
    test_arithmetic_guards();
    test_function_guards();
    test_complex_struct_patterns();
    test_reference_patterns();
    test_mutable_reference_patterns();
    test_slice_range_combinations();
    test_box_patterns();
    test_complex_or_patterns();
    test_string_patterns();
    test_boolean_logic_guards();
    test_exhaustiveness();
    
    print("Advanced pattern matching tests completed!");
    return 0;
}
