// Advanced pattern matching tests with edge cases

// Test 1: Deeply nested patterns
fn test_deep_nesting() Int {
    complex_data = ((Point(1, 2), [3, 4, 5]), Option::Some((6, 7)));
    
    match complex_data {
        ((Point { x: 0, y: 0 }, _), _) => print("Origin in nested structure"),
        ((Point { x, y }, [a, b, c]), Option::Some((d, e))) if x + y == a + b + c + d + e => {
            print("All numbers sum to same value");
        },
        ((Point { x, y }, slice), Option::Some((d, e))) => {
            print("Point " + to_string_int(x) + "," + to_string_int(y) + " with slice and tuple");
        },
        ((_, _), Option::None) => print("Nested with none"),
        _ => print("Complex no match"),
    }
    
    return 0;
}

// Test 2: Pattern matching with arithmetic in guards
fn test_arithmetic_guards() Int {
    value = 42;
    
    match value {
        n if n * 2 == 84 => print("Double is 84"),
        n if n / 2 == 21 => print("Half is 21"),
        n if n % 10 == 2 => print("Ends with 2"),
        n if n > 0 && n < 100 => print("Positive two-digit"),
        _ => print("Other arithmetic condition"),
    }
    
    return 0;
}

// Test 3: Pattern matching with function calls in guards
fn is_even(x: Int) Bool {
    return x % 2 == 0;
}

fn is_prime(x: Int) Bool {
    if x < 2 {
        return false;
    }
    if x == 2 {
        return true;
    }
    if x % 2 == 0 {
        return false;
    }
    i = 3;
    while i * i <= x {
        if x % i == 0 {
            return false;
        }
        i = i + 2;
    }
    return true;
}

fn test_function_guards() Int {
    num = 17;
    
    match num {
        n if is_even(n) => print("Even number: " + to_string_int(n)),
        n if is_prime(n) => print("Prime number: " + to_string_int(n)),
        n if n > 50 => print("Large number: " + to_string_int(n)),
        _ => print("Other number: " + to_string_int(n)),
    }
    
    return 0;
}

// Test 4: Complex struct patterns with nested structs
struct Rectangle {
    top_left: Point,
    bottom_right: Point,
}

struct Circle {
    center: Point,
    radius: Int,
}

enum Shape {
    Rectangle(Rectangle),
    Circle(Circle),
    Point(Point),
}

fn test_complex_struct_patterns() Int {
    rect = Rectangle(Point(0, 10), Point(20, 0));
    circle = Circle(Point(5, 5), 3);
    
    shape1 = Shape::Rectangle(rect);
    shape2 = Shape::Circle(circle);
    
    match shape1 {
        Shape::Rectangle(Rectangle { top_left: Point { x: 0, y: y }, bottom_right: Point { x: x, y: 0 } }) => {
            print("Rectangle from origin: " + to_string_int(x) + "x" + to_string_int(y));
        },
        Shape::Rectangle(rect) => print("Other rectangle"),
        Shape::Circle(Circle { center: Point { x: 5, y: 5 }, radius: r }) => {
            print("Circle at (5,5) with radius " + to_string_int(r));
        },
        _ => print("Other shape"),
    }
    
    return 0;
}

