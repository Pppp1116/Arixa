// Test 7: Pattern matching with slices and ranges
fn test_slice_range_combinations() Int {
    data = [1, 2, 3, 4, 5, 6, 7, 8];
    
    match data {
        [] => print("Empty slice"),
        [x] if x > 0 => print("Single positive: " + to_string_int(x)),
        [x, y] if x + y == 10 => print("Two numbers summing to 10"),
        [1, 2, 3, ..] => print("Starts with 1,2,3"),
        [.., 6, 7, 8] => print("Ends with 6,7,8"),
        [.., middle, ..] if middle > 5 => print("Middle element > 5"),
        [a, b, c, d, e, f, g, h] => {
            print("Full slice: " + to_string_int(a) + "," + to_string_int(b) + "," + to_string_int(c) + "," + 
                  to_string_int(d) + "," + to_string_int(e) + "," + to_string_int(f) + "," + 
                  to_string_int(g) + "," + to_string_int(h));
        },
    }
    
    return 0;
}

