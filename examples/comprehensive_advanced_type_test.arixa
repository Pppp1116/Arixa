// Test 9: Complex Where Clauses
fn complex_generic_function<T, U, V, W>(
    a: T, 
    b: U, 
    c: V, 
    d: W
) Bool 
where 
    T: Display + Eq + Clone,
    U: Display + Ord + Clone,
    V: Clone + Copy,
    W: Display
{
    a_displayed = a.display();
    a_cloned = a.clone();
    a_equal = a.eq(a_cloned);
    
    b_displayed = b.display();
    b_compared = b.cmp(b);
    b_cloned = b.clone();
    
    v_cloned = c.clone();
    v_copied = c.clone();
    
    w_displayed = d.display();
    
    return a_equal and (b_compared == 0);
}

fn test_complex_where() Int {
    result = complex_generic_function<Int, String, Bool, Float>(
        42, 
        "hello", 
        true, 
        3.14
    );
    
    print("Complex where clauses work!");
    return if result { 1 } else { 0 };
}

// Test 10: Generic Type Inference
fn generic_type_inference() Int {
    // Function with inferred generic types
    fn create_pair<T, U>(first: T, second: U) Pair<T, U> {
        return Pair<T, U>(first, second);
    }
    
    // Type inference should work here
    pair1 = create_pair(42, "hello");
    pair2 = create_pair(true, 3.14);
    
    print("Generic type inference work!");
    return pair1.first;
}

// Test 11: Union Types with Pattern Matching
fn advanced_union_matching(value: Int | String | Bool | Point<Int> | Point<String>) String {
    match value {
        x if x is Int => "Integer: " + x.display(),
        s if s is String => "String: " + s,
        b if b is Bool => "Boolean: " + if b { "true" } else { "false" },
        p if p is Point<Int> => "Int Point: " + p.display(),
        p if p is Point<String> => "String Point: " + p.display(),
    }
}

fn test_advanced_union_matching() Int {
    int_point = Point<Int>(10, 20);
    string_point = Point<String>("x", "y");
    
    result1 = advanced_union_matching(42);
    result2 = advanced_union_matching("hello");
    result3 = advanced_union_matching(true);
    result4 = advanced_union_matching(int_point);
    result5 = advanced_union_matching(string_point);
    
    print("Advanced union matching work!");
    return 0;
}

// Test 12: Generic Constraints with Multiple Traits
fn multi_trait_function<T>(item: T) String 
where 
    T: Display + Debug + Clone + Eq + Ord
{
    // Use all trait bounds
    displayed = item.display();
    debugged = item.debug();
    cloned = item.clone();
    equal = item.eq(cloned);
    compared = item.cmp(item);
    
    return displayed + " (debug: " + debugged + ", cmp: " + to_string_int(compared) + ")";
}

