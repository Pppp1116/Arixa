// Test 5: Nested unsafe blocks
fn test_nested_unsafe() Int {
    x = 10;
    
    unsafe {
        y = x + 5;
        
        unsafe {
            z = y * 2;
            print("Nested unsafe: " + to_string_int(z));
        }
        
        print("Outer unsafe: " + to_string_int(y));
    }
    
    return 0;
}

// Test 6: Unsafe with control flow
fn test_unsafe_control_flow() Int {
    x = 1;
    
    unsafe {
        if x > 0 {
            y = x * 10;
            print("Unsafe if: " + to_string_int(y));
        }
        
        for i in 0..3 {
            unsafe {
                j = i * 2;
                print("Unsafe for: " + to_string_int(j));
            }
        }
    }
    
    return 0;
}

