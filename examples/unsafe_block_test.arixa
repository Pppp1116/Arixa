fn main() Int {
    print("Testing unsafe blocks...");
    
    test_basic_unsafe();
    test_unsafe_casts();
    test_raw_pointers();
    test_unsafe_functions();
    test_nested_unsafe();
    test_unsafe_control_flow();
    test_unsafe_structs();
    test_unsafe_error_handling();
    test_unsafe_arrays();
    test_unsafe_boundaries();
    test_unsafe_function_call();
    test_unsafe_memory();
    
    print("All unsafe block tests completed!");
    return 0;
}
