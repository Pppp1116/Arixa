// Test 10: Unsafe block boundaries
fn test_unsafe_boundaries() Int {
    x = 10;
    
    unsafe {
        y = x + 20;
        print("Inside: " + to_string_int(y));
    }
    
    // This should be safe and allowed
    z = x + 30;
    print("Outside: " + to_string_int(z));
    
    // This should cause an error:
    // unsafe_operation();  // ERROR: requires unsafe context
    
    return 0;
}

// Test 11: Unsafe in functions
unsafe fn unsafe_function(x: Int) Int {
    return x * 2;
}

fn test_unsafe_function_call() Int {
    // This should require unsafe context
    unsafe {
        result = unsafe_function(21);
        print("Unsafe function result: " + to_string_int(result));
    }
    
    return 0;
}

