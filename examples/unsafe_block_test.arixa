import std.mem;

// Test 1: Basic unsafe block
fn test_basic_unsafe() Int {
    x = 42;
    
    unsafe {
        // Safe operations inside unsafe block
        y = x * 2;
        print("Inside unsafe block: " + to_string_int(y));
    }
    
    print("Outside unsafe block: " + to_string_int(x));
    return 0;
}

