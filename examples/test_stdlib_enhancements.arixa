import std.str;

import std.data;

import std.algorithm;

import std.math;

fn main() Int {
    print("Testing enhanced standard library...");
    test_string_utilities();
    test_math_functions();
    print("All tests completed!");
    return 0;
}

fn test_string_utilities() {
    print("Testing string utilities...");
    str_len = length("Hello, World!");
    print("Length: " + to_string_int(str_len));
    sub = substring("Hello, World!", 7, 5);
    print("Substring: " + sub);
    starts = starts_with("Hello, World!", "Hello");
    print("Starts with 'Hello': " + to_string_bool(starts));
    ends = ends_with("Hello, World!", "World!");
    print("Ends with 'World!': " + to_string_bool(ends));
    upper = to_upper("Hello, World!");
    print("Uppercase: " + upper);
    lower = to_lower("Hello, World!");
    print("Lowercase: " + lower);
}

fn test_math_functions() {
    print("Testing math functions...");
    a = 10;
    b = 3;
    print("min_int(10, 3): " + to_string_int(min_int(a, b)));
    print("max_int(10, 3): " + to_string_int(max_int(a, b)));
    print("abs_int(-5): " + to_string_int(abs_int(-5)));
    print("clamp_int(15, 0, 10): " + to_string_int(clamp_int(15, 0, 10)));
    x = 3.14159;
    y = 2.71828;
    print("min_float(3.14159, 2.71828): " + to_string_float(min_float(x, y)));
    print("max_float(3.14159, 2.71828): " + to_string_float(max_float(x, y)));
    print("abs_float(-2.5): " + to_string_float(abs_float(-2.5)));
    angle = PI / 4.0;
    sin_val = sin(angle);
    cos_val = cos(angle);
    print("sin(\u03c0/4): " + to_string_float(sin_val));
    print("cos(\u03c0/4): " + to_string_float(cos_val));
    print("PI: " + to_string_float(PI));
    print("E: " + to_string_float(E));
}

fn vec_to_string(vec Vec<Int>) String {
    mut result = "[";
    mut i = 0;
    mut first = true;
    while i < vec_len(vec) {
        val = vec_get(vec, i);
        if val != none {
            if !first {
                result += ", ";
            }
            else {
                first = false;
            }
            val_int = val as Int | none ?? 0;
            result += to_string_int(val_int);
        }
        else {}
        i += 1;
    }
    result += "]";
    return result;
}
