gpu fn vec_add(a GpuSlice<Float>, b GpuSlice<Float>, out GpuMutSlice<Float>) {
    i = gpu.global_id();
    if i < out.len() {
        out[i] = a[i] + b[i];
    }
    else {}
}

fn main() Int {
    x: Vec<Float> = [1.0, 2.0, 3.0, 4.0];
    y: Vec<Float> = [10.0, 20.0, 30.0, 40.0];
    dx = gpu.copy(x);
    dy = gpu.copy(y);
    dout: GpuBuffer<Float> = gpu.alloc(len(x));
    gpu.launch(vec_add, len(x), 256, dx, dy, dout);
    print(gpu.read(dout));
    return 0;
}
