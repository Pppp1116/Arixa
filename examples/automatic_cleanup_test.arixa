import std.mem;

// Example: ownership + scope cleanup without raw alloc/free builtins.

struct Resource {
    id Int,
}

fn make_resource(id Int) Resource {
    return Resource(id);
}

fn test_scope_cleanup() Int {
    {
        inner = make_resource(1);
        print("inner ready");
        _ = inner.id;
    }

    outer = make_resource(2);
    print("outer ready");
    return outer.id;
}

fn test_move_cleanup() Int {
    first = make_resource(10);
    second = first;
    return second.id;
}

fn test_collection_cleanup() Int {
    mut xs: Vec<Int> = vec_new() as Vec<Int>;
    vec_push(xs, 1);
    vec_push(xs, 2);
    vec_push(xs, 3);
    return vec_len(xs);
}

fn main() Int {
    a = test_scope_cleanup();
    b = test_move_cleanup();
    c = test_collection_cleanup();
    return a + b + c;
}
