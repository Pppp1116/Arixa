fn test_unsafe_exceptions() Int {
    unsafe {
        // Exception handling in unsafe context
        // try {
        //     unsafe_operation();
        // } catch {
        //     handle_error();
        // }
        print("Unsafe exception handling");
    }
    
    return 0;
