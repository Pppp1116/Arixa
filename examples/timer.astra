fn ms() Int{
    return __monotonic_ms();
}

fn main() Int{
    t0 = ms();
    mut i = 0;
    mut x = 0.0;
    while i < 20000000 {
        x = x * 1.0000001 + 0.5;
        if x > 1000000.0 {
            x = x / 2.0;
        }
        else {}
        i += 1;
    }
    t1 = ms();
    dt = t1 - t0;
    print(dt);
    print(x);
    return 0;
}
