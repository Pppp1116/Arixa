{
  "name": "arixa-language",
  "displayName": "Arixa Language",
  "description": "Complete VS Code support for Arixa with enhanced syntax highlighting, IntelliSense, package management, and GPU development tools.",
  "version": "0.6.5",
  "icon": "images/arixa.png",
  "publisher": "arixa-lang",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "arixa",
    "astra",
    "language",
    "lsp",
    "gpu",
    "cuda",
    "package-manager",
    "enhanced-syntax"
  ],
  "files": [
    "extension.js",
    "language-configuration.json",
    "syntaxes/**",
    "snippets/**",
    "server/**",
    "images/**",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "arixa",
        "aliases": [
          "Arixa",
          "Arixa",
          "arixa",
          "astra"
        ],
        "extensions": [
          ".arixa"
        ],
        "icon": {
          "light": "images/arixa.png",
          "dark": "images/arixa.png"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "arixa",
        "scopeName": "source.arixa",
        "path": "./syntaxes/arixa.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "arixa",
        "path": "./snippets/arixa.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "arixa.restartLanguageServer",
        "title": "Arixa: Restart Language Server"
      },
      {
        "command": "arixa.showLanguageServerStatus",
        "title": "Arixa: Show Language Server Status"
      },
      {
        "command": "arixa.openExtensionLog",
        "title": "Arixa: Open Extension Log"
      },
      {
        "command": "arixa.buildCurrentFile",
        "title": "Arixa: Build Current File"
      },
      {
        "command": "arixa.runCurrentFile",
        "title": "Arixa: Run Current File"
      },
      {
        "command": "arixa.checkForToolchainUpdates",
        "title": "Arixa: Check Toolchain Updates"
      },
      {
        "command": "arixa.initPackage",
        "title": "Arixa: Initialize Package"
      },
      {
        "command": "arixa.publishPackage",
        "title": "Arixa: Publish Package"
      },
      {
        "command": "arixa.searchPackages",
        "title": "Arixa: Search Packages"
      },
      {
        "command": "arixa.installPackage",
        "title": "Arixa: Install Package"
      },
      {
        "command": "arixa.listPackages",
        "title": "Arixa: List Installed Packages"
      },
      {
        "command": "arixa.generateDocs",
        "title": "Arixa: Generate Documentation"
      },
      {
        "command": "arixa.runBenchmarks",
        "title": "Arixa: Run Benchmarks"
      },
      {
        "command": "arixa.newProject",
        "title": "Arixa: New Project"
      },
      {
        "command": "arixa.gpuCompile",
        "title": "Arixa: Compile for GPU"
      },
      {
        "command": "arixa.showEnhancedErrors",
        "title": "Arixa: Show Enhanced Error Messages"
      },
      {
        "command": "arixa.showPackageManager",
        "title": "Arixa: Show Package Manager"
      },
      {
        "command": "arixa.showProfiler",
        "title": "Arixa: Show Profiler"
      },
      {
        "command": "arixa.startDebugging",
        "title": "Arixa: Start Debugging"
      }
    ],
    "configuration": {
      "title": "Arixa",
      "properties": {
        "arixa.languageServer.mode": {
          "type": "string",
          "enum": [
            "bundled",
            "external"
          ],
          "default": "bundled",
          "description": "How to start the language server. Bundled mode auto-provisions a private toolchain in VS Code storage, then tries workspace dist/toolchain/bin/arlsp, then falls back to the server shipped inside this extension."
        },
        "arixa.languageServer.command": {
          "type": "string",
          "default": "",
          "description": "Executable used to launch the Arixa language server in external mode."
        },
        "arixa.languageServer.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python executable used for bundled server mode (optional override)."
        },
        "arixa.languageServer.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional command line arguments passed to the external Arixa language server."
        },
        "arixa.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace level for language server protocol logs."
        },
        "arixa.compiler.mode": {
          "type": "string",
          "enum": [
            "bundled",
            "external"
          ],
          "default": "bundled",
          "description": "How to run compiler commands from VS Code. Bundled mode auto-provisions a private toolchain in VS Code storage, then tries workspace dist/toolchain/bin/arixa, then falls back to the compiler copy shipped in this extension."
        },
        "arixa.compiler.command": {
          "type": "string",
          "default": "",
          "description": "Executable used to launch the Arixa compiler in external mode."
        },
        "arixa.compiler.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python executable used for bundled compiler mode (optional override)."
        },
        "arixa.compiler.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional command line arguments passed before compiler subcommands in external mode."
        },
        "arixa.compiler.target": {
          "type": "string",
          "enum": [
            "py",
            "llvm",
            "native",
            "gpu"
          ],
          "default": "native",
          "description": "Default target for `Arixa: Build Current File`."
        },
        "arixa.compiler.outputDir": {
          "type": "string",
          "default": ".arixa-build",
          "description": "Output directory for `Arixa: Build Current File` (absolute or workspace-relative)."
        },
        "arixa.compiler.buildArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra CLI arguments appended to `arixa build`."
        },
        "arixa.enhancedErrors.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable enhanced error messages with suggestions and context."
        },
        "arixa.enhancedErrors.showSuggestions": {
          "type": "boolean",
          "default": true,
          "description": "Show actionable suggestions for fixing errors."
        },
        "arixa.enhancedErrors.showNotes": {
          "type": "boolean",
          "default": true,
          "description": "Show contextual notes for errors."
        },
        "arixa.packageManager.autoInstall": {
          "type": "boolean",
          "default": false,
          "description": "Automatically install missing packages when detected."
        },
        "arixa.packageManager.registryUrl": {
          "type": "string",
          "default": "https://registry.astra-lang.org",
          "description": "Package registry URL for discovery and installation."
        },
        "arixa.gpu.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable GPU development features and CUDA compilation."
        },
        "arixa.gpu.defaultBackend": {
          "type": "string",
          "enum": [
            "cuda",
            "stub"
          ],
          "default": "cuda",
          "description": "Default GPU backend for compilation."
        },
        "arixa.formatting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic formatting on save."
        },
        "arixa.formatting.indentSize": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 8,
          "description": "Number of spaces for indentation."
        },
        "arixa.linting.enabled": {
          "type": "boolean",
          "default": "true",
          "description": "Enable linting and code quality checks."
        },
        "arixa.linting.warningsAsErrors": {
          "type": "boolean",
          "default": false,
          "description": "Treat warnings as errors in diagnostics."
        },
        "arixa.intelliSense.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable enhanced IntelliSense features."
        },
        "arixa.intelliSense.autoImport": {
          "type": "boolean",
          "default": true,
          "description": "Automatically suggest imports for unresolved symbols."
        },
        "arixa.documentation.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable documentation generation and hover information."
        },
        "arixa.toolchain.autoUpdateCheck": {
          "type": "boolean",
          "default": true,
          "description": "Periodically check online for newer Arixa toolchain versions."
        },
        "arixa.toolchain.checkIntervalHours": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "description": "How often to check for toolchain updates (hours)."
        },
        "arixa.toolchain.updateChannel": {
          "type": "string",
          "enum": [
            "stable",
            "prerelease"
          ],
          "default": "stable",
          "description": "Update channel for online toolchain checks."
        },
        "arixa.toolchain.updateManifestUrl": {
          "type": "string",
          "default": "https://raw.githubusercontent.com/Pppp1116/ARIXA/main/registry/toolchain-updates.json",
          "description": "Manifest URL used by the online toolchain update checker."
        }
      }
    },
    "configurationDefaults": {
      "[arixa]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.detectIndentation": false,
        "editor.rulers": [
          100
        ],
        "editor.wordWrap": "on",
        "editor.renderWhitespace": "boundary",
        "editor.guides.indentation": true,
        "editor.bracketPairColorization.enabled": true,
        "editor.minimap.enabled": false,
        "editor.fontLigatures": false,
        "editor.semanticHighlighting.enabled": true,
        "editor.inlayHints.enabled": "on",
        "editor.codeActionsOnSave.enabled": true,
        "editor.suggest.insertMode": "replace",
        "editor.acceptSuggestionOnEnter": "on"
      }
    },
    "keybindings": [
      {
        "key": "ctrl+shift+b",
        "command": "arixa.buildCurrentFile",
        "when": "editorLangId == arixa"
      },
      {
        "key": "ctrl+shift+r",
        "command": "arixa.runCurrentFile",
        "when": "editorLangId == arixa"
      },
      {
        "key": "ctrl+shift+p",
        "command": "arixa.publishPackage",
        "when": "editorLangId == arixa"
      },
      {
        "key": "ctrl+shift+s",
        "command": "arixa.searchPackages",
        "when": "editorLangId == arixa"
      },
      {
        "key": "f5",
        "command": "arixa.runCurrentFile",
        "when": "editorLangId == arixa"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorLangId == arixa",
          "command": "arixa.buildCurrentFile",
          "group": "navigation@1"
        },
        {
          "when": "editorLangId == arixa",
          "command": "arixa.runCurrentFile",
          "group": "navigation@2"
        },
        {
          "when": "editorLangId == arixa",
          "command": "arixa.gpuCompile",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        {
          "command": "arixa.initPackage",
          "when": "false"
        },
        {
          "command": "arixa.publishPackage",
          "when": "false"
        },
        {
          "command": "arixa.searchPackages",
          "when": "false"
        },
        {
          "command": "arixa.installPackage",
          "when": "false"
        },
        {
          "command": "arixa.listPackages",
          "when": "false"
        },
        {
          "command": "arixa.newProject",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "arixa.showLanguageServerStatus",
          "when": "arixa:showStatusBar",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "arixa-explorer",
          "title": "Arixa",
          "icon": "$(package)"
        }
      ]
    },
    "views": {
      "arixa-explorer": [
        {
          "id": "arixa-packages",
          "name": "Packages",
          "when": "arixa:showPackages",
          "icon": "$(package)"
        },
        {
          "id": "arixa-gpu",
          "name": "GPU Development",
          "when": "arixa:showGPU",
          "icon": "$(pulse)"
        },
        {
          "id": "arixa-tools",
          "name": "Tools",
          "when": "arixa:showTools",
          "icon": "$(tools)"
        }
      ]
    },
    "colors": [
      {
        "id": "arixa.keywords",
        "description": "Keywords in Arixa",
        "colors": {
          "keyword.control": "#569CD6",
          "keyword.operator": "#D4D4D4",
          "keyword.type": "#4EC9B0"
        }
      },
      {
        "id": "arixa.types",
        "description": "Types in Arixa",
        "colors": {
          "type.primitive": "#4EC9B0",
          "type.user": "#9CDCFE",
          "type.generic": "#BD8CFF"
        }
      },
      {
        "id": "arixa.functions",
        "description": "Functions in Arixa",
        "colors": {
          "function.declaration": "#DCDCAA",
          "function.call": "#DCDCAA",
          "function.builtin": "#569CD6"
        }
      },
      {
        "id": "arixa.gpu",
        "description": "GPU development features",
        "colors": {
          "gpu.kernel": "#FF6B6B",
          "gpu.builtin": "#4EC9B0"
        }
      }
    ],
    "debuggers": [
      {
        "type": "astra",
        "label": "Arixa Debug",
        "program": "./debugger/astra-debug-adapter.js",
        "runtime": "node",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the Arixa program to debug"
              },
              "target": {
                "type": "string",
                "enum": [
                  "native",
                  "llvm",
                  "gpu"
                ],
                "default": "native",
                "description": "Compilation target for debugging"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Arguments to pass to the program"
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the debugged program"
              },
              "env": {
                "type": "object",
                "description": "Environment variables for the debugged program"
              },
              "stopOnEntry": {
                "type": "boolean",
                "default": true,
                "description": "Automatically stop after launch"
              }
            }
          },
          "attach": {
            "properties": {
              "processId": {
                "type": "number",
                "description": "Process ID to attach to"
              },
              "port": {
                "type": "number",
                "default": 4711,
                "description": "Port to connect to"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "astra",
            "name": "Debug Arixa Program",
            "request": "launch",
            "program": "${workspaceFolder}/${command:AskForProgramName}",
            "target": "native",
            "stopOnEntry": true
          },
          {
            "type": "astra",
            "name": "Debug GPU Program",
            "request": "launch",
            "program": "${workspaceFolder}/${command:AskForProgramName}",
            "target": "gpu",
            "stopOnEntry": true
          }
        ]
      }
    ]
  },
  "scripts": {
    "bundle-server": "node ./scripts/bundle-server.js",
    "check-sync": "python ../../scripts/verify_editor_sync.py",
    "lint": "echo 'No lint step configured'",
    "package": "npm run bundle-server && npm run check-sync && npx @vscode/vsce package --allow-missing-repository",
    "publish:oneclick": "python ../../scripts/release_vscode_extension.py --publish --npm-update"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.88.0",
    "@vscode/vsce": "^3.6.2"
  },
  "license": "MIT"
}
