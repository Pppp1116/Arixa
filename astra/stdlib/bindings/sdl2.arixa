extern fn SDL_Delay(ms u32);

@link("SDL2")
extern fn SDL_GetError() *u8;

@link("SDL2")
extern fn SDL_PollEvent(event *Void) i32;

SDL_INIT_VIDEO: u32 = 32 as u32;

SDL_INIT_AUDIO: u32 = 16 as u32;

SDL_INIT_EVERYTHING: u32 = 65535 as u32;

SDL_WINDOWPOS_CENTERED: i32 = 805240832 as i32;

