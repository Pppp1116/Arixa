@link("SDL2")
extern fn SDL_Init(flags u32) i32;

@link("SDL2")
extern fn SDL_Quit();

@link("SDL2")
extern fn SDL_CreateWindow(title *u8, x i32, y i32, w i32, h i32, flags u32) *Void;

@link("SDL2")
extern fn SDL_DestroyWindow(win *Void);

@link("SDL2")
extern fn SDL_CreateRenderer(win *Void, index i32, flags u32) *Void;

@link("SDL2")
extern fn SDL_DestroyRenderer(renderer *Void);

@link("SDL2")
extern fn SDL_RenderClear(renderer *Void) i32;

@link("SDL2")
extern fn SDL_RenderPresent(renderer *Void);

@link("SDL2")
extern fn SDL_SetRenderDrawColor(renderer *Void, r u8, g u8, b u8, a u8) i32;

