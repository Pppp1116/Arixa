/// std.sync - hosted synchronization primitives backed by runtime mutexes.

/// Create a mutex handle.
fn mutex_new() Any{
    return __mutex_new();
}

/// Acquire lock for current owner task id.
fn mutex_lock(m Any, owner_tid Int) Int{
    return __mutex_lock(m as Int, owner_tid);
}

/// Release lock for current owner task id.
fn mutex_unlock(m Any, owner_tid Int) Int{
    return __mutex_unlock(m as Int, owner_tid);
}
